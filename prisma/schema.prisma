// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Version {
  id       Int     @id @default(autoincrement())
  name     String  @unique // e.g., "NVI", "KJV"
  language String  // e.g., "pt", "en"
  books    Book[]
}

model Book {
  id        Int      @id @default(autoincrement())
  abbrev    String
  name      String
  chapters  Int      @default(1)
  versionId Int
  version   Version  @relation(fields: [versionId], references: [id])
  verses    Verse[]

  @@unique([abbrev, versionId])
}

model Verse {
  id      Int    @id @default(autoincrement())
  bookId  Int
  book    Book   @relation(fields: [bookId], references: [id])
  chapter Int
  verse   Int
  text    String

  @@index([chapter])
  @@index([verse])
}
